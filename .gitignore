# Node modules
node_modules/
out/

# Build output
*.js
*.js.map
!src/templates/**/*.js
dist/
.next/
build/
storybook-static/
bun.lockb

# OS files
.DS_Store
Thumbs.db

# IDE
.idea/
*.swp
*.swo

# Logs
*.log

# Test files
.vscode/terminals/logs/
.vscode/terminals/pending/
*.vsix

# Local state (machine-specific) — ignore contents EXCEPT the committed
# project identity file (project.json carries the stable project_id UUID +
# name; committed so teammates/clones share one memory partition — see
# docs/plans/identity-model.md). Use `.immorterm/*` (not `.immorterm/`) so the
# negation can take effect; git won't descend into a wholly-ignored dir.
.immorterm/*
!.immorterm/project.json
# Dev mode sentinel (never ship — gates license dev overrides)
.dev
.vscode/local-history/
.tilt.pid
screenlog.*

# Moon build cache
.moon/cache/

# Python
__pycache__/
*.pyc

# npm pack artifacts
*.tgz

# Claude Code local settings (contains secrets)
.claude/settings.local.json

# Research artifacts (large generated analysis files)
services/memory/docs/research/

# Rust
target/
.cargo/

# Environment
.env
.env.local
.env.*.local

# Moon docker scaffold output (generated by `moon docker scaffold <project>`).
# Also a guard against the scaffold regenerating into the workspace and
# confusing local tooling.
.moon/docker/

# Temporary lockfile snapshots from install-parity comparisons.
bun.lock.mac
bun.lock.linux

# WASM dev artifacts (test pages, screenshots, font files)
apps/immorterm-ai/immorterm-wasm/screenshots/
apps/immorterm-ai/immorterm-wasm/*.png
apps/immorterm-ai/immorterm-wasm/*.html
apps/immorterm-ai/immorterm-wasm/web/*.ttf
apps/immorterm-ai/immorterm-wasm/web/*.html
apps/immorterm-ai/immorterm-wasm/web/pkg
apps/immorterm-ai/immorterm-wasm/web/*.mjs
apps/immorterm-ai/immorterm-wasm/src/fonts/

# Test results
test-results/

# Python venv
.venv/

# Native binary build artifacts
packages/immorterm-memory-*/bin/
packages/immorterm-memory/bin/

# Claude worktrees + ephemeral runtime files (NEVER commit — worktrees are
# multi-GB working copies, scheduled_tasks.lock is a runtime mutex).
.claude/worktrees/
.claude/scheduled_tasks.lock

# Background-task transcripts and cache
.claude/projects/*/tasks/
.claude/projects/*/tool-results/

# Generated by ImmorTerm hook installer (rewritten on extension activation
# from `apps/extension/src/services/memory/hook-installer.ts` heredoc).
# Project ID, paths, and project-specific values are machine-local. The
# installer is the source of truth — these files are outputs. Same goes
# for the per-vendor hook configs the installer materializes alongside
# Claude's: Codex, Cursor, Windsurf, Cline, opencode, Copilot.
.claude/hooks/
.claude/commands/immorterm/
.codex/
.cursor/
.windsurf/
.clinerules/
.github/hooks/immorterm.json
opencode.json

# Per-project MCP config — contains machine-local paths (target/debug/...)
# and a `_reconnect_ts` field that mcp-gateway touches on every reconnect,
# making the file noisy in `git status`. Generated/maintained per machine.
.mcp.json

# Tauri sidecar binary output (compiled hub artifact for desktop bundling).
apps/immorterm-app/src-tauri/binaries/

# Tauri updater signing keys. Private key MUST NEVER land in git. The
# public key (.key.pub) is fine to commit and is baked into the app via
# tauri.conf.json > plugins.updater.pubkey, but we keep it alongside
# .key here and both live outside of source control. Release CI gets
# the private key via TAURI_SIGNING_PRIVATE_KEY env var (GitHub secret).
.tauri/

# Internal working docs — never publish (repo is PUBLIC)
docs/openclaw/
docs/plans/digest-rust-port-v2-*.md
docs/plans/feature-*-clustering.md
docs/plans/feature-3-cross-session-agent-search.md
docs/plans/memory-standalone-productization.md
docs/terminal-comparison.md

# fumadocs generated source + TS incremental build info
apps/docs/.source/
*.tsbuildinfo
