#!/usr/bin/env sh
set -e
cd "$(git rev-parse --show-toplevel)"
export PATH="/opt/homebrew/bin:$HOME/.bun/bin:$HOME/.cargo/bin:$PATH"
# Scoped to the daemon-relevant crates only — NOT the whole workspace (which
# blocked pushes on unrelated WIP in the monorepo). wasm + extension compile
# are left to CI (too slow for pre-push).
echo "→ pre-push: cargo clippy (immorterm-core, immorterm-render, immorterm-daemon)"
cargo clippy -p immorterm-core -p immorterm-render -p immorterm-daemon -- -D warnings || {
  echo "✗ clippy failed. Fix, or bypass once with: git push --no-verify"; exit 1; }
echo "✓ pre-push checks passed"
