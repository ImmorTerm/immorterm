{
	"name": "@immorterm/ui",
	"version": "0.1.0",
	"description": "React component library for ImmorTerm (ships TypeScript source; consumers transpile)",
	"license": "FSL-1.1-Apache-2.0",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ImmorTerm/immorterm.git",
		"directory": "libs/ui"
	},
	"type": "module",
	"main": "./src/index.ts",
	"types": "./src/index.ts",
	"exports": {
		".": "./src/index.ts",
		"./styles.css": "./src/styles.css"
	},
	"files": [
		"src",
		"!src/*.stories.tsx"
	],
	"sideEffects": [
		"**/*.css"
	],
	"scripts": {
		"storybook": "storybook dev -p ${PORT:-6006} --no-open",
		"build-storybook": "storybook build"
	},
	"dependencies": {
		"@immorterm/menu-data": "workspace:^",
		"@immorterm/tier-config": "workspace:^"
	},
	"devDependencies": {
		"@storybook/addon-a11y": "^10.4.6",
		"@storybook/react-vite": "^10.4.6",
		"@tailwindcss/vite": "^4.1.0",
		"@types/react": "catalog:",
		"@types/react-dom": "catalog:",
		"@vitejs/plugin-react": "^6.0.3",
		"react": "catalog:",
		"react-dom": "catalog:",
		"storybook": "^10.4.6",
		"tailwindcss": "^4.1.0",
		"vite": "^8.1.2"
	},
	"peerDependencies": {
		"clsx": "*",
		"lucide-react": "*",
		"react": "*",
		"react-dom": "*",
		"tailwind-merge": "*"
	}
}
