{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"plugins": [
			{
				"name": "next"
			}
		],
		"module": "ESNext",
		"moduleResolution": "bundler",
		// fumadocs-mdx's generated .source/server.ts feeds an empty `DocData: {}`
		// into its create<> generic; with the base's noUncheckedIndexedAccess,
		// `TC['DocData'][name]` becomes `undefined` and the doc-entry intersection
		// collapses to `never`, erasing `page.data.body`/`.toc`. Off for this app.
		"noUncheckedIndexedAccess": false,
		"allowJs": true,
		"noEmit": true,
		"declaration": false,
		"declarationMap": false,
		"incremental": true,
		"paths": {
			"@/*": ["./*"],
			"@immorterm/ui": ["../../libs/ui/src"],
			"@immorterm/menu-data": ["../../libs/menu-data/src"],
			"@immorterm/tier-config": ["../../libs/tier-config/src"]
		},
		"jsx": "preserve"
	},
	"include": [".source/**/*.ts", "next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
	"exclude": ["node_modules"]
}
