		"next": "^14.2.0",
		"react": "catalog:",
		"react-dom": "catalog:",
		"lucide-react": "catalog:ui",
		"tailwind-merge": "catalog:ui",
		"clsx": "catalog:ui"
	},
	"devDependencies": {
		"@types/mdx": "^2.0.13",
		"@types/react": "catalog:",
		"@types/react-dom": "catalog:",
		"autoprefixer": "^10",
		"postcss": "^8",
		"tailwindcss": "^3.4.0",
		"typescript": "catalog:"
	}
