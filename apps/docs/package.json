{
	"name": "@immorterm/docs",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "next dev --port ${PORT:-3097}",
		"build": "bunx fumadocs-mdx && bunx next build",
