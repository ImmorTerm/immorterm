{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ImmorTerm",
  "version": "0.1.0",
  "identifier": "com.immorterm.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1440",
    "beforeDevCommand": "node ../../scripts/build-menu-data.mjs",
    "beforeBuildCommand": "node ../../scripts/build-menu-data.mjs",
    "beforeBundleCommand": "node ../../scripts/build-hub-sidecar.mjs"
  },
  "app": {
    "windows": [],
    "withGlobalTauri": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/immorterm-hub"
    ],
    "resources": [
      "../../extension/resources/**/*"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDlDNjE1ODVGODM3MjgxQkEKUldTNmdYS0RYMWhobk5CZjVjSXNjRjhqeE02VHYvNmt1TFlITm9PZEE4UzdpUWlUMXRuUFlacHcK",
      "endpoints": [
        "https://github.com/ImmorTerm/immorterm/releases/latest/download/latest.json"
      ]
    }
  }
}
